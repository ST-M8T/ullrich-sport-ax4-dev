###############################################################################
# AX4 Admin – ENV Example
#
# Diese Datei ist die Vorlage für `.env`. Sie wird im CI als Basis kopiert
# (`cp .env.example .env`). Echte Secrets gehören NUR in `.env` und werden
# über `.gitignore` ausgeschlossen.
###############################################################################

# === Application ===
APP_NAME=AX4
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=de
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=de_DE
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database
# APP_PREVIOUS_KEYS=

# === Logging ===
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# === Datenbank (Primary) ===
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ax4
DB_USERNAME=ax4
DB_PASSWORD=
# DB_URL=
# DB_SOCKET=
# DB_CHARSET=utf8mb4
# DB_COLLATION=utf8mb4_unicode_ci
# DB_FOREIGN_KEYS=true
# DB_ENCRYPT=
# DB_TRUST_SERVER_CERTIFICATE=

# === AX4-Source-DB (Read-only Anbindung an Legacy-AX4) ===
AX4_SOURCE_DB_HOST=
AX4_SOURCE_DB_PORT=3306
AX4_SOURCE_DB_DATABASE=
AX4_SOURCE_DB_USERNAME=
AX4_SOURCE_DB_PASSWORD=
AX4_SOURCE_DB_CHARSET=utf8mb4
AX4_SOURCE_DB_COLLATION=utf8mb4_unicode_ci

# === Auth ===
AUTH_GUARD=web
# AUTH_MODEL optional; Standard: Infrastructure UserModel (siehe config/auth.php).
AUTH_PASSWORD_BROKER=users
# AUTH_PASSWORD_RESET_TOKEN_TABLE=password_reset_tokens
# AUTH_PASSWORD_TIMEOUT=10800
BCRYPT_ROUNDS=12

# === API-Auth ===
# Public-API-Key für /v1/* Endpunkte (X-API-Key Header).
# Wenn leer: Public-API ist offen — NICHT in Production setzen.
API_ACCESS_KEY=

# Admin-API-Token für /admin/* Endpunkte (Bearer / X-Admin-Token).
# Wenn leer: Admin-API verweigert alle Anfragen.
ADMIN_API_TOKEN=

# === Cache ===
CACHE_STORE=database
# CACHE_PREFIX=ax4
# DB_CACHE_CONNECTION=
# DB_CACHE_TABLE=cache
# DB_CACHE_LOCK_CONNECTION=
# DB_CACHE_LOCK_TABLE=cache_locks

# === Session ===
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# === Queue ===
QUEUE_CONNECTION=database
# DB_QUEUE_CONNECTION=
# DB_QUEUE_TABLE=jobs
# DB_QUEUE=default
# DB_QUEUE_RETRY_AFTER=90
# BEANSTALKD_QUEUE_HOST=
# BEANSTALKD_QUEUE=default
# BEANSTALKD_QUEUE_RETRY_AFTER=90

# === Broadcast ===
BROADCAST_CONNECTION=log

# === Filesystem ===
FILESYSTEM_DISK=local
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=eu-central-1
# AWS_BUCKET=
# AWS_URL=
# AWS_ENDPOINT=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# === Mail ===
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"

# === Memcached / Redis ===
MEMCACHED_HOST=127.0.0.1
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# === DHL Freight Integration ===
DHL_API_KEY=
DHL_AUTH_BASE_URL=
DHL_AUTH_PATH=/auth
DHL_AUTH_PASSWORD=
DHL_AUTH_TIMEOUT=10
DHL_AUTH_CONNECT_TIMEOUT=5
DHL_AUTH_RETRY_TIMES=3
DHL_AUTH_RETRY_SLEEP=200
DHL_AUTH_TOKEN_CACHE_TTL=3600
DHL_AUTH_LOG_CHANNEL=stack

# === Plenty Integration ===
# Wird über system_settings statt ENV konfiguriert (siehe ConfigurationServiceProvider).
# Lokale Override:
# PLENTY_BASE_URL=
# PLENTY_API_USER=
# PLENTY_API_PASSWORD=

# === Vite ===
VITE_APP_NAME="${APP_NAME}"

# === Telescope/Pulse/Nightwatch (lokale Tools) ===
# TELESCOPE_ENABLED=false
# PULSE_ENABLED=false
# NIGHTWATCH_ENABLED=false

###############################################################################
# Hinweise
# - Vor jeder neuen Variable in der Anwendung: hier eintragen mit Dummy-Wert.
# - Echte Secrets nur in `.env`. Niemals committen.
# - Komplette Variablen-Liste: `grep -rohE "env\(['\"][A-Z_]+" config app | sort -u`.
###############################################################################
